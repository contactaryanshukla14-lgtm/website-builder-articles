# Copy this to .env after you create platform-specific tokens.
# Use app passwords/API tokens/service-account keys, not your main passwords.

# Publishing controls
PUBLISH_MODE=draft
DEFAULT_CANONICAL_URL=

# DEV Community / Forem
# Create in DEV account settings: Settings -> Extensions -> DEV API Keys
DEVTO_API_KEY=

# WordPress.com or self-hosted WordPress
# Option A: WordPress.com OAuth/Bearer token + site id
WORDPRESS_COM_ACCESS_TOKEN=
WORDPRESS_COM_SITE_ID=
# Option B: self-hosted WordPress application password
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# Blogger
# Requires Google OAuth credentials and a blog id.
BLOGGER_BLOG_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Medium
# Medium no longer issues new integration tokens. Existing tokens only.
MEDIUM_INTEGRATION_TOKEN=

# Hashnode
# Requires Hashnode API access/token and publication id/host if available.
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Google Sheets / Drive final tracker
# Preferred API path: Google Cloud service-account JSON with Sheets + Drive APIs enabled.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SHEET_SHARE_WITH_EMAIL=
GOOGLE_SHEET_SHARE_PUBLIC=false
